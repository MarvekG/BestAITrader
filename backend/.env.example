# 项目基本信息
PROJECT_NAME=天枢智投
PROJECT_VERSION=v1.0.0

# 必填字段（启动校验：以下两个字段不能留空）
#   FIRST_SUPERUSER_PASSWORD  初始超级用户密码
#   SECRET_KEY                JWT 签名密钥
# 可用 python -c "import secrets; print(secrets.token_urlsafe(48))" 生成

# 必填，初始用户和密码
FIRST_SUPERUSER=tradeuser
FIRST_SUPERUSER_EMAIL=tradeuser@example.com
FIRST_SUPERUSER_PASSWORD=

# 必填，安全配置
SECRET_KEY=

# 必填，LLM配置；默认通过 LiteLLM 网关访问 litellm/config.yaml 中的模型别名
LLM_PROVIDER=litellm
LLM_MODEL=openai-compatible
LLM_THINKING_MODEL=openai-compatible-thinking
LLM_API_KEY=sk-litellm-gateway-key
LLM_BASE_URL=http://litellm:4000/v1
LLM_TIMEOUT_SECONDS=240
LLM_MAX_RETRIES=3
# 可选：辩论模式、经验复盘、AI选股使用的投研专用 LLM Key；为空则使用 LLM_API_KEY
RESEARCH_LLM_API_KEY=
# 调试用：辩论内部 Agent 是否并行执行，默认 true
DEBATE_AGENT_PARALLEL_ENABLED=true

# 功能开关：默认开启；不使用这些功能或做生产安全加固时，应显式改为 false
ENABLE_AUTO_TRADE=true
ENABLE_TESTING_ENDPOINTS=true
ENABLE_RUNTIME_EXTENSIONS=true
ENABLE_OPENAPI_DOCS=true
BACKEND_CORS_ORIGINS=[]

# 后台异步任务最大并发数；阻塞外部 API 调用继续复用 asyncio 默认线程池
ASYNC_TASK_MAX_CONCURRENT=8

# 盯盘事件保留天数；清理任务每天执行一次，默认保留 30 天
MARKET_WATCH_EVENT_RETENTION_DAYS=30

# Python 沙箱服务；Compose 内默认指向独立 sandbox 容器
PY_SANDBOX_ENABLED=true
PY_SANDBOX_BASE_URL=http://sandbox:8030
PY_SANDBOX_HTTP_TIMEOUT_SECONDS=35
PY_SANDBOX_TIMEOUT_SECONDS=30
PY_SANDBOX_STDOUT_MAX_BYTES=32768
PY_SANDBOX_STDERR_MAX_BYTES=16384

# Webfetch 服务；Compose 内默认指向独立 webfetch 容器
WEBFETCH_BASE_URL=http://webfetch:8010
WEBFETCH_TIMEOUT_SECONDS=180

# 必填，TUSHARE配置（需要2000积分）
TUSHARE_API=http://api.waditu.com/dataapi
TUSHARE_TOKEN=your-tushare-token
# Tushare API 调用频率限制
TUSHARE_MAX_CALLS_PER_MINUTE=500

# 默认数据源选项: tushare；当前就只有一个数据源。
DEFAULT_DATA_SOURCE=tushare
ENABLE_DATA_SOURCE_FAILOVER=true

# System Language (zh/en)
SYSTEM_LANGUAGE=zh

# 必填，tavily API，注册https://app.tavily.com后获取
TAVILY_API_KEY=your_tavily_api_key

# 必填，NewsAPI API Key，注册https://newsapi.org后获取（免费层 100次/天）
NEWS_API_KEY=your_newsapi_key
